# ---- Google AI / Gemini ------------------------------------------------------
# Get a key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Human-readable store name. The job creates this store on first run, then
# reuses it. After creation, the real resource name is persisted in
# data/state/store.json (and also acceptable here).
GOOGLE_FILE_SEARCH_STORE_DISPLAY_NAME=optibot-support-kb
GOOGLE_FILE_SEARCH_STORE_NAME=

# Model used by the local assistant query helper.
GEMINI_MODEL=gemini-2.5-flash

# ---- Source ------------------------------------------------------------------
SUPPORT_BASE_URL=https://support.optisigns.com
ARTICLE_LIMIT=30

# ---- Job behaviour -----------------------------------------------------------
# Set to false to run the full scrape/clean/delta path without calling Google
# (useful for smoke tests and CI without secrets).
UPLOAD_ENABLED=true

# Local chunk estimate + provider chunking config. Google AI File Search
# enforces max_tokens_per_chunk in [0, 512]; 512 with a 64-token overlap
# (≈12.5%) keeps chunks in the retrieval window while preserving context.
# `logs/last_run.json` reports an estimated chunk count (the API does not
# return an exact count).
MAX_TOKENS_PER_CHUNK=512
MAX_OVERLAP_TOKENS=64

LOG_LEVEL=INFO
